{
  "name": "sudoku-solver",
  "version": "4.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "clean": "rimraf dist",
    "format": "prettier --write \"./**/*.{css,scss,html,js,mjs,json,md,ts}\"",
    "lint": "eslint . --fix --max-warnings 0",
    "build": "ng build",
    "test": "ng test --watch=false",
    "e2e": "ng e2e",
    "cp3rdpartylicenses": "copyfiles -f dist/sudoku-solver-angular/3rdpartylicenses.txt dist/sudoku-solver-angular/browser",
    "deployghpages": "gh-pages -d dist/sudoku-solver-angular/browser",
    "watch": "ng build --watch --configuration development",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.12",
    "@angular/cdk": "21.2.10",
    "@angular/common": "21.2.12",
    "@angular/compiler": "21.2.12",
    "@angular/core": "21.2.12",
    "@angular/forms": "21.2.12",
    "@angular/material": "21.2.10",
    "@angular/platform-browser": "21.2.12",
    "@angular/platform-browser-dynamic": "21.2.12",
    "@angular/router": "21.2.12",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "fast-sudoku-solver": "3.0.3",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/architect": "0.2102.10",
    "@angular-devkit/core": "21.2.10",
    "@angular-devkit/schematics": "21.2.10",
    "@angular/build": "21.2.10",
    "@angular/cli": "21.2.10",
    "@angular/compiler-cli": "21.2.12",
    "@cypress/schematic": "5.0.0",
    "@eslint/js": "10.0.1",
    "angular-eslint": "21.3.1",
    "copyfiles": "2.4.1",
    "cypress": "15.15.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "gh-pages": "6.3.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.4",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.3",
    "vitest": "4.1.6"
  },
  "lint-staged": {
    "*.{html,js,mjs,ts}": [
      "prettier --write",
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ],
    "*.{css,scss,json,md}": "prettier --write"
  }
}
